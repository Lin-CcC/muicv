{
  "name": "@muicv/app",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Mui简历桌面端：electron + React，让不用 AI agent 的求职者也能跑完整简历工作流。",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit",
    "package": "electron-vite build && electron-builder --mac --publish never",
    "package:mac": "electron-vite build && electron-builder --mac --publish never",
    "package:mac:arm": "electron-vite build && electron-builder --mac --arm64 --publish never",
    "package:mac:x64": "electron-vite build && electron-builder --mac --x64 --publish never",
    "preview": "electron-vite preview"
  },
  "dependencies": {
    "@muicv/shared": "workspace:*",
    "@openai/agents": "^0.8.5",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "fast-glob": "^3.3.3",
    "openai": "^6.34.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^22.19.17",
    "@types/react": "19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "postcss": "^8.5.10",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "zustand": "^5.0.10"
  }
}
