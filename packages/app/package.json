{
  "name": "@muicv/app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3070",
    "build": "next build",
    "cf:build": "opennextjs-cloudflare build --config wrangler.jsonc",
    "cf:preview": "opennextjs-cloudflare preview --config wrangler.jsonc",
    "dev:cf": "opennextjs-cloudflare preview --config wrangler.jsonc",
    "cf:deploy": "opennextjs-cloudflare deploy --config wrangler.jsonc",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "start": "next start",
    "db:migrate:local": "wrangler -c wrangler.jsonc d1 migrations apply MUICV_DB --local",
    "db:migrate": "wrangler -c wrangler.jsonc d1 migrations apply MUICV_DB",
    "test": "node --test"
  },
  "dependencies": {
    "@muicv/shared": "workspace:*",
    "@muicv/ui": "workspace:*",
    "next": "~16.0.10",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^22.19.5",
    "@types/react": "19.2.7",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  }
}
