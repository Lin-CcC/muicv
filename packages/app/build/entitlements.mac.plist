<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Electron 运行时必需：V8 JIT / dyld / 联网。hardenedRuntime 开了之后这些默认禁用，
       不显式声明会让 Electron 启动直接 crash 或 sandbox 拒绝联网。 -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <true/>
  <key>com.apple.security.network.client</key>
  <true/>
  <!-- 麦克风访问（issue #1 模拟面试录音）。Hardened Runtime 下必须显式声明，
       否则 getUserMedia 会被 sandbox 拒绝，即便已有 NSMicrophoneUsageDescription。 -->
  <key>com.apple.security.device.audio-input</key>
  <true/>
</dict>
</plist>
