{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "muicv-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-23",
  "compatibility_flags": ["nodejs_compat"],
  "account_id": "fdc63eeea83ae8f5234357308b9a638b",
  "routes": [
    {
      "pattern": "api.muicv.com/*",
      "zone_name": "muicv.com"
    }
  ],
  "browser": {
    "binding": "BROWSER"
  },
  "ai": {
    "binding": "AI"
  },
  // BrowserContainer 已下线；v1/v2 migration 必须留着，否则 Cloudflare 会拒部署。
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["BrowserContainer"]
    },
    {
      "tag": "v2",
      "deleted_classes": ["BrowserContainer"]
    }
  ],
  // KV / D1 与 packages/website 共用同一份资源（id 必须保持一致）。
  "kv_namespaces": [
    {
      "binding": "MUICV_KV",
      "id": "3db8f70ff2494a798b06ba699adc6d5a"
    }
  ],
  "d1_databases": [
    {
      "binding": "MUICV_API_DB",
      "database_name": "muicv",
      "database_id": "db60cfbd-48e1-4220-9239-18c117f26ed0",
      "migrations_dir": "migrations"
    }
  ],
  // 简历素材加密同步 blob，公开域名 i.muicv.com（按需开启 access policy）。
  // MUICV_PHOTOS：在线预览 / PDF 用的证件照，公开读取（puppeteer 要能 fetch 到外链）。
  "r2_buckets": [
    {
      "binding": "MUICV_RESUME_BLOB",
      "bucket_name": "muicv"
    },
    {
      "binding": "MUICV_PHOTOS",
      "bucket_name": "muicv"
    }
  ],
  // Readability / turndown 在 puppeteer page 内 addScriptTag，作为文本资源 import。
  "rules": [
    {
      "type": "Text",
      "globs": ["**/Readability.js", "**/turndown.js"],
      "fallthrough": true
    }
  ],
  "vars": {
    "RENDER_BASE_URL": "https://muicv.com",
    "PHOTOS_PUBLIC_BASE_URL": "https://i.muicv.com",
    "PREVIEW_PUBLIC_BASE_URL": "https://muicv.com",
    "STRIPE_PRICE_PRO_MONTHLY": "price_1TRwa8EpkXm2vxXTYEgJaDVp",
    "STRIPE_PRICE_PRO_YEARLY": "price_1TRwb4EpkXm2vxXTP56EkfBh",
    "STRIPE_PRICE_MAX_MONTHLY": "price_1TRwcYEpkXm2vxXTolTABRBM",
    "STRIPE_PRICE_MAX_YEARLY": "price_1TRwczEpkXm2vxXTxoxuOYjq"
  },
  "observability": {
    "enabled": true
  },
  "placement": {
    "mode": "smart"
  }
}
