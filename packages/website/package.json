{
  "name": "@muicv/website",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Mui简历 web app：landing page (muicv.com) 和将来的 dashboard。Next.js + OpenNext on Cloudflare Worker。",
  "scripts": {
    "dev": "next dev -p 3070",
    "build": "next build",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "db:migrate:local": "wrangler d1 migrations apply muicv --local",
    "db:migrate": "wrangler d1 migrations apply muicv --remote",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "@muicv/shared": "workspace:*",
    "@muicv/ui": "workspace:*",
    "better-auth": "^1.6.9",
    "drizzle-orm": "^0.45.2",
    "gray-matter": "^4.0.3",
    "marked": "^18.0.2",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.4",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^22.19.17",
    "@types/react": "19.2.7",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "wrangler": "^4.85.0"
  }
}
